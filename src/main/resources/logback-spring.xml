<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 콘솔로 출력해주는 기사 ConsoleAppender   -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- 파일로 저장하는 기사 RollingFileAppender : 설정한 rollingPolicy에 따라 자정이 넘었다?? -> 로그는 창고에 넣고, 오늘 날짜로 새 파일을 생성하며 파일을 쪼개고 관리   -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>./logs/chatting.log</file>

        <rollingPolicy
            class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>
                ./logs/chatting-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss} %-5level - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- 해결책, 내 패키지(폴더)에만 logger 매니저를 따로 배치하여 그곳을 지나는 로그 레벨만 DEBUG로 -->
    <logger name="com.example.chattingroom" level="DEBUG"/>

    <!-- 실무에서는 무조건 root 총괄매니저는 INFO로 닫아둡니다 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="FILE" />
    </root>
</configuration>