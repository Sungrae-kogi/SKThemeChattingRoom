# =========================
# 1. 보안 및 설정 파일 (가장 중요!)
# =========================
# DB 비밀번호 등 민감 정보가 포함된 파일
*.properties
*.yml
*.yaml

# =========================
# 2. 실행 로그 파일
# =========================
# 서버가 돌아가며 쌓아두는 텍스트 찌꺼기
logs/
*.log

# =========================
# 3. 빌드 결과물 (용량 낭비 방지)
# =========================
# 소스코드를 컴파일해서 나온 결과물들
target/
*.class
*.jar
*.war
.mvn/wrapper/maven-wrapper.jar

# =========================
# 4. 에디터(IDE) 개인 설정
# =========================
# 개발자 PC마다 다른 환경 설정 파일
.idea/
*.iml
*.iws
out/

# =========================
# 5. OS 임시 파일
# =========================
# 맥이나 윈도우가 몰래 만드는 숨김 파일
.DS_Store
Thumbs.db

# =========================
# 6. GitHub Actions 예외 허용
# =========================
# .yml은 막더라도, 워크플로우 폴더 안의 파일은 허용해라(!)
!.github/workflows/*.yml